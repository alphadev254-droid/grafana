{
  "uid": "app-overview",
  "title": "App Overview",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "tags": ["apps", "icims"],
  "timezone": "browser",
  "panels": [
    {
      "type": "timeseries",
      "title": "HTTP Requests per Minute",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(icims_backend_http_requests_total[1m])) by (job)",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "5xx Errors per Minute",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(icims_backend_http_requests_total{status_code=~\"5..\"}[1m])) by (job)",
          "legendFormat": "{{job}} 5xx"
        }
      ]
    },
    {
      "type": "logs",
      "title": "Recent App Logs",
      "gridPos": { "x": 0, "y": 8, "w": 24, "h": 10 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{job=\"host-apps\"}"
        }
      ]
    }
  ]
}
