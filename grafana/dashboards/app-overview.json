{
  "uid": "app-overview",
  "title": "App Overview",
  "schemaVersion": 39,
  "version": 3,
  "refresh": "10s",
  "tags": [
    "apps",
    "icims"
  ],
  "timezone": "browser",
  "panels": [
    {
      "type": "stat",
      "title": "Requests in Selected Range",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(increase(icims_backend_http_requests_total{method=~\"$method\",route=~\"$route\",status_code=~\"$status_code\"}[$__range]))",
          "legendFormat": "selected range"
        }
      ]
    },
    {
      "type": "stat",
      "title": "2xx in Selected Range",
      "gridPos": {
        "x": 4,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(increase(icims_backend_http_requests_total{method=~\"$method\",route=~\"$route\",status_code=~\"2..\"}[$__range]))",
          "legendFormat": "2xx"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Errors in Selected Range",
      "gridPos": {
        "x": 8,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(increase(icims_backend_http_requests_total{method=~\"$method\",route=~\"$route\",status_code=~\"4..|5..\"}[$__range]))",
          "legendFormat": "4xx + 5xx"
        }
      ]
    },
    {
      "type": "stat",
      "title": "In-flight Requests",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(icims_backend_http_requests_in_flight{method=~\"$method\",route=~\"$route\"})",
          "legendFormat": "in-flight"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Backend Memory",
      "gridPos": {
        "x": 16,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "decimals": 1,
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "icims_backend_process_resident_memory_bytes",
          "legendFormat": "rss"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Backend Uptime",
      "gridPos": {
        "x": 20,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 0,
          "color": {
            "mode": "fixed",
            "fixedColor": "green"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "time() - icims_backend_process_start_time_seconds",
          "legendFormat": "uptime"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Logins in Selected Range",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 8,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(increase(icims_backend_auth_login_attempts_total[$__range])) by (status) or vector(0)",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Payments in Selected Range",
      "gridPos": {
        "x": 8,
        "y": 4,
        "w": 8,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(increase(icims_backend_payment_events_total[$__range])) by (status) or vector(0)",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Withdrawals in Selected Range",
      "gridPos": {
        "x": 16,
        "y": 4,
        "w": 8,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(increase(icims_backend_withdrawal_events_total[$__range])) by (status) or vector(0)",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP Requests over Time (tw=1m)",
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "links": [
            {
              "title": "Open request logs for this time range",
              "url": "/d/icims-logs/icims-logs?from=${__from}&to=${__to}&var-level=.*&var-event=http_request&var-requestId=&var-route=&var-statusCode=&var-userId=&var-churchId=",
              "targetBlank": false
            }
          ]
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(increase(icims_backend_http_requests_total{method=~\"$method\",route=~\"$route\",status_code=~\"$status_code\"}[1m]))",
          "legendFormat": "requests"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Status Codes over Time (tw=1m)",
      "gridPos": {
        "x": 12,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "links": [
            {
              "title": "Open request logs for this time range",
              "url": "/d/icims-logs/icims-logs?from=${__from}&to=${__to}&var-level=.*&var-event=http_request&var-requestId=&var-route=&var-statusCode=&var-userId=&var-churchId=",
              "targetBlank": false
            }
          ]
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "2xx"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "green"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "4xx"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "orange"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "5xx"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "red"
                }
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(increase(icims_backend_http_requests_total{method=~\"$method\",route=~\"$route\",status_code=~\"2..\"}[1m]))",
          "legendFormat": "2xx"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(increase(icims_backend_http_requests_total{method=~\"$method\",route=~\"$route\",status_code=~\"4..\"}[1m]))",
          "legendFormat": "4xx"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(increase(icims_backend_http_requests_total{method=~\"$method\",route=~\"$route\",status_code=~\"5..\"}[1m]))",
          "legendFormat": "5xx"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Requests by Route over Time (tw=1m)",
      "gridPos": {
        "x": 0,
        "y": 16,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "links": [
            {
              "title": "Open logs for this route",
              "url": "/d/icims-logs/icims-logs?from=${__from}&to=${__to}&var-level=.*&var-event=http_request&var-requestId=&var-route=${__field.labels.route}&var-statusCode=&var-userId=&var-churchId=",
              "targetBlank": false
            }
          ]
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(increase(icims_backend_http_requests_total{method=~\"$method\",route=~\"$route\",status_code=~\"$status_code\"}[1m])) by (route)",
          "legendFormat": "{{route}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Backend CPU (tw=1m)",
      "gridPos": {
        "x": 12,
        "y": 16,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 3
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "rate(icims_backend_process_cpu_seconds_total[1m])",
          "legendFormat": "cpu cores"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Route p95 Response Time over Time (tw=1m)",
      "gridPos": {
        "x": 0,
        "y": 24,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 3,
          "links": [
            {
              "title": "Open logs for this route",
              "url": "/d/icims-logs/icims-logs?from=${__from}&to=${__to}&var-level=.*&var-event=http_request&var-requestId=&var-route=${__field.labels.route}&var-statusCode=&var-userId=&var-churchId=",
              "targetBlank": false
            }
          ]
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "histogram_quantile(0.95, sum(rate(icims_backend_http_request_duration_seconds_bucket{method=~\"$method\",route=~\"$route\",status_code=~\"$status_code\"}[1m])) by (le, route))",
          "legendFormat": "{{route}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Route Status Codes over Time (tw=1m)",
      "gridPos": {
        "x": 12,
        "y": 24,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "links": [
            {
              "title": "Open logs for this route and status",
              "url": "/d/icims-logs/icims-logs?from=${__from}&to=${__to}&var-level=.*&var-event=http_request&var-requestId=&var-route=${__field.labels.route}&var-statusCode=${__field.labels.status_code}&var-userId=&var-churchId=",
              "targetBlank": false
            }
          ]
        },
        "overrides": [
          {
            "matcher": {
              "id": "byRegexp",
              "options": ".* 2\\d\\d$"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "green"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": ".* 4\\d\\d$"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "orange"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": ".* 5\\d\\d$"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "red"
                }
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(increase(icims_backend_http_requests_total{method=~\"$method\",route=~\"$route\",status_code=~\"$status_code\"}[1m])) by (route, status_code)",
          "legendFormat": "{{route}} {{status_code}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Login Attempts over Time (tw=1m)",
      "gridPos": {
        "x": 0,
        "y": 32,
        "w": 8,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(increase(icims_backend_auth_login_attempts_total[1m])) by (status)",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Payments over Time (tw=1m)",
      "gridPos": {
        "x": 8,
        "y": 32,
        "w": 8,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(increase(icims_backend_payment_events_total[1m])) by (status)",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Withdrawals over Time (tw=1m)",
      "gridPos": {
        "x": 16,
        "y": 32,
        "w": 8,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(increase(icims_backend_withdrawal_events_total[1m])) by (status)",
          "legendFormat": "{{status}}"
        }
      ]
    }
  ],
  "templating": {
    "list": [
      {
        "name": "method",
        "type": "query",
        "label": "Method",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(icims_backend_http_requests_total, method)",
        "refresh": 1,
        "sort": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "hide": 0
      },
      {
        "name": "route",
        "type": "query",
        "label": "Route",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(icims_backend_http_requests_total, route)",
        "refresh": 1,
        "sort": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "hide": 0
      },
      {
        "name": "status_code",
        "type": "query",
        "label": "Status Code",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(icims_backend_http_requests_total, status_code)",
        "refresh": 1,
        "sort": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "hide": 0
      }
    ]
  }
}
