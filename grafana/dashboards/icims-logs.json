{
  "id": null,
  "uid": "icims-logs",
  "title": "ICIMS Logs",
  "tags": [
    "icims",
    "logs",
    "loki"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10m",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "level",
        "type": "custom",
        "label": "Level",
        "query": "all,debug,info,warn,error",
        "current": {
          "text": "all",
          "value": "all"
        },
        "options": [],
        "hide": 0
      },
      {
        "name": "event",
        "type": "custom",
        "label": "Event",
        "query": "all,http_request,unhandled_error,auth_login_attempt,payment_event,withdrawal_event",
        "current": {
          "text": "all",
          "value": "all"
        },
        "options": [],
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "type": "stat",
      "title": "Errors in Selected Range",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": {
            "mode": "fixed",
            "fixedColor": "red"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "sum(count_over_time({service=\"icims-backend\"} | json | level=\"error\" [$__range]))",
          "legendFormat": "errors"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Warnings in Selected Range",
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": {
            "mode": "fixed",
            "fixedColor": "orange"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "sum(count_over_time({service=\"icims-backend\"} | json | level=\"warn\" [$__range]))",
          "legendFormat": "warnings"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Payment Events in Selected Range",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "sum(count_over_time({service=\"icims-backend\"} | json | event=\"payment_event\" [$__range]))",
          "legendFormat": "payments"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Withdrawal Events in Selected Range",
      "gridPos": {
        "x": 18,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "sum(count_over_time({service=\"icims-backend\"} | json | event=\"withdrawal_event\" [$__range]))",
          "legendFormat": "withdrawals"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Log Volume by Level",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "sum by (level) (count_over_time({service=\"icims-backend\"} | json [1m]))",
          "legendFormat": "{{level}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Key Events Over Time",
      "gridPos": {
        "x": 12,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "sum by (event) (count_over_time({service=\"icims-backend\"} | json | event =~ \"auth_login_attempt|payment_event|withdrawal_event|unhandled_error\" [1m]))",
          "legendFormat": "{{event}}"
        }
      ]
    },
    {
      "type": "logs",
      "title": "Errors",
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "{service=\"icims-backend\"} | json | level=\"error\""
        }
      ]
    },
    {
      "type": "logs",
      "title": "Login, Payment, and Withdrawal Events",
      "gridPos": {
        "x": 12,
        "y": 12,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "{service=\"icims-backend\"} | json | event =~ \"auth_login_attempt|payment_event|withdrawal_event\""
        }
      ]
    },
    {
      "type": "logs",
      "title": "Recent Backend Logs",
      "gridPos": {
        "x": 0,
        "y": 20,
        "w": 24,
        "h": 10
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "{service=\"icims-backend\"} | json"
        }
      ]
    }
  ]
}
