{
  "id": null,
  "uid": "icims-logs",
  "title": "ICIMS Logs",
  "tags": [
    "icims",
    "logs",
    "loki"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "10m",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "level",
        "type": "custom",
        "label": "Level",
        "query": ".*,debug,info,warn,error",
        "multi": false,
        "includeAll": false,
        "current": {
          "text": "All",
          "value": ".*"
        },
        "hide": 0
      },
      {
        "name": "event",
        "type": "custom",
        "label": "Event",
        "query": ".*,http_request,unhandled_error,auth_login_attempt,payment_event,withdrawal_event",
        "multi": false,
        "includeAll": false,
        "current": {
          "text": "All",
          "value": ".*"
        },
        "hide": 0
      },
      {
        "name": "requestId",
        "type": "textbox",
        "label": "Request ID",
        "query": "",
        "current": {
          "text": "",
          "value": ""
        },
        "hide": 0
      },
      {
        "name": "route",
        "type": "textbox",
        "label": "Route contains",
        "query": "",
        "current": {
          "text": "",
          "value": ""
        },
        "hide": 0
      },
      {
        "name": "statusCode",
        "type": "textbox",
        "label": "Status code",
        "query": "",
        "current": {
          "text": "",
          "value": ""
        },
        "hide": 0
      },
      {
        "name": "userId",
        "type": "textbox",
        "label": "User ID",
        "query": "",
        "current": {
          "text": "",
          "value": ""
        },
        "hide": 0
      },
      {
        "name": "churchId",
        "type": "textbox",
        "label": "Church ID",
        "query": "",
        "current": {
          "text": "",
          "value": ""
        },
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "type": "stat",
      "title": "HTTP/App Errors in Selected Range",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": {
            "mode": "fixed",
            "fixedColor": "red"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "sum(count_over_time({service=\"icims-backend\"} |= \"$requestId\" |= \"$route\" |= \"$statusCode\" |= \"$userId\" |= \"$churchId\" |~ \"^\\\\{\" | json | __error__=\"\" | level=~\"$level\" | event=~\"$event\" | level=\"error\" [$__range])) + sum(count_over_time({service=\"icims-backend\"} |= \"$requestId\" |= \"$route\" |= \"$statusCode\" |= \"$userId\" |= \"$churchId\" |~ \"^\\\\{\" | json | __error__=\"\" | level=~\"$level\" | event=~\"$event\" | event=\"http_request\" | statusCode >= 400 [$__range]))",
          "legendFormat": "errors"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Warnings in Selected Range",
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": {
            "mode": "fixed",
            "fixedColor": "orange"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "sum(count_over_time({service=\"icims-backend\"} |= \"$requestId\" |= \"$route\" |= \"$statusCode\" |= \"$userId\" |= \"$churchId\" |~ \"^\\\\{\" | json | __error__=\"\" | level=~\"$level\" | event=~\"$event\" | level=\"warn\" [$__range]))",
          "legendFormat": "warnings"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Payment Events in Selected Range",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "sum(count_over_time({service=\"icims-backend\"} |= \"$requestId\" |= \"$route\" |= \"$statusCode\" |= \"$userId\" |= \"$churchId\" |~ \"^\\\\{\" | json | __error__=\"\" | level=~\"$level\" | event=~\"$event\" | event=\"payment_event\" [$__range]))",
          "legendFormat": "payments"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Withdrawal Events in Selected Range",
      "gridPos": {
        "x": 18,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "sum(count_over_time({service=\"icims-backend\"} |= \"$requestId\" |= \"$route\" |= \"$statusCode\" |= \"$userId\" |= \"$churchId\" |~ \"^\\\\{\" | json | __error__=\"\" | level=~\"$level\" | event=~\"$event\" | event=\"withdrawal_event\" [$__range]))",
          "legendFormat": "withdrawals"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Structured Log Volume by Level (tw=1m)",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "sum by (log_level) (count_over_time({service=\"icims-backend\"} |= \"$requestId\" |= \"$route\" |= \"$statusCode\" |= \"$userId\" |= \"$churchId\" |~ \"^\\\\{\" | json | __error__=\"\" | level=~\"$level\" | event=~\"$event\" | label_format log_level=\"{{.level}}\" [1m]))",
          "legendFormat": "{{log_level}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Key Events Over Time (tw=1m)",
      "gridPos": {
        "x": 12,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "sum by (key_event) (count_over_time({service=\"icims-backend\"} |= \"$requestId\" |= \"$route\" |= \"$statusCode\" |= \"$userId\" |= \"$churchId\" |~ \"^\\\\{\" | json | __error__=\"\" | level=~\"$level\" | event=~\"$event\" | event =~ \"auth_login_attempt|payment_event|withdrawal_event|unhandled_error\" | label_format key_event=\"{{.event}}\" [1m]))",
          "legendFormat": "{{key_event}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP 4xx/5xx Over Time (tw=1m)",
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 24,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "sum(count_over_time({service=\"icims-backend\"} |= \"$requestId\" |= \"$route\" |= \"$statusCode\" |= \"$userId\" |= \"$churchId\" |~ \"^\\\\{\" | json | __error__=\"\" | level=~\"$level\" | event=~\"$event\" | event=\"http_request\" | statusCode >= 400 | statusCode < 500 [1m]))",
          "legendFormat": "4xx"
        },
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "sum(count_over_time({service=\"icims-backend\"} |= \"$requestId\" |= \"$route\" |= \"$statusCode\" |= \"$userId\" |= \"$churchId\" |~ \"^\\\\{\" | json | __error__=\"\" | level=~\"$level\" | event=~\"$event\" | event=\"http_request\" | statusCode >= 500 [1m]))",
          "legendFormat": "5xx"
        }
      ]
    },
    {
      "type": "logs",
      "title": "HTTP Error Request Logs",
      "gridPos": {
        "x": 0,
        "y": 20,
        "w": 24,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "{service=\"icims-backend\"} |= \"$requestId\" |= \"$route\" |= \"$statusCode\" |= \"$userId\" |= \"$churchId\" |~ \"^\\\\{\" | json | __error__=\"\" | level=~\"$level\" | event=~\"$event\" | event=\"http_request\" | statusCode >= 400"
        }
      ]
    },
    {
      "type": "logs",
      "title": "App Error Logs",
      "gridPos": {
        "x": 0,
        "y": 28,
        "w": 24,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "{service=\"icims-backend\"} |= \"$requestId\" |= \"$route\" |= \"$statusCode\" |= \"$userId\" |= \"$churchId\" |~ \"^\\\\{\" | json | __error__=\"\" | level=~\"$level\" | event=~\"$event\" | level=\"error\""
        }
      ]
    },
    {
      "type": "logs",
      "title": "Login, Payment, and Withdrawal Events",
      "gridPos": {
        "x": 0,
        "y": 36,
        "w": 24,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "{service=\"icims-backend\"} |= \"$requestId\" |= \"$route\" |= \"$statusCode\" |= \"$userId\" |= \"$churchId\" |~ \"^\\\\{\" | json | __error__=\"\" | level=~\"$level\" | event=~\"$event\" | event =~ \"auth_login_attempt|payment_event|withdrawal_event\""
        }
      ]
    },
    {
      "type": "logs",
      "title": "Recent Backend Logs",
      "gridPos": {
        "x": 0,
        "y": 44,
        "w": 24,
        "h": 10
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "{service=\"icims-backend\"} |= \"$requestId\" |= \"$route\" |= \"$statusCode\" |= \"$userId\" |= \"$churchId\" |~ \"^\\\\{\" | json | __error__=\"\" | level=~\"$level\" | event=~\"$event\""
        }
      ]
    },
    {
      "type": "logs",
      "title": "Slow Requests from Logs",
      "gridPos": {
        "x": 0,
        "y": 54,
        "w": 24,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "{service=\"icims-backend\"} |= \"$requestId\" |= \"$route\" |= \"$statusCode\" |= \"$userId\" |= \"$churchId\" |~ \"^\\\\{\" | json | __error__=\"\" | level=~\"$level\" | event=~\"$event\" | event=\"http_request\" | durationMs >= 1000"
        }
      ]
    }
  ]
}
